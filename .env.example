# Copy this file to .env. Values are read only by the Python backend.

OPENROUTER_API_KEY=
# Comma-separated free model IDs. Only entries listed here appear in Model.
OPENROUTER_MODELS=
# Legacy single-model form remains supported: OPENROUTER_MODEL=openrouter/free
# Optional override when the selected endpoint advertises a different maximum.
# OPENROUTER_CONTEXT_WINDOW=131072
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
# OPENROUTER_SITE_URL=https://your-app.example
# OPENROUTER_APP_NAME=Selene

# NVIDIA API Catalog / hosted NIM. One key can access every model enabled for
# that account; set a comma-separated list of only the IDs you want shown.
NVIDIA_API_KEY=
NVIDIA_MODELS=
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
# Set this to the selected endpoints' supported maximum; defaults to 131072.
# NVIDIA_CONTEXT_WINDOW=131072

GEMINI_API_KEY=
# Free chat/tool models supported by Selene (verified 2026-07-20). Remove any
# models you do not want shown in the selector; keep the list comma-separated.
# Keep gemini-3.1-flash-lite in this list to enable the first automatic fallback.
GEMINI_MODELS=gemini-3.5-flash,gemini-3.1-flash-lite,gemini-3-flash-preview,gemini-2.5-pro,gemini-2.5-flash,gemini-2.5-flash-lite,gemma-4-31b-it,gemma-4-26b-a4b-it
# Selene knows the native maximum for each listed model. Override only when a
# compatible gateway enforces a smaller limit.
# GEMINI_CONTEXT_WINDOW=1048576
# Legacy single-model form remains supported: GEMINI_MODEL=gemini-3.5-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Optional OpenAI-compatible or self-hosted provider. The API key may be left
# empty when the endpoint does not require authentication.
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_MODEL=
# Set this to the endpoint's advertised maximum; defaults to 131072.
# CUSTOM_LLM_CONTEXT_WINDOW=131072
